{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Accounting App",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "console": "integratedTerminal"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Run Accounting Tests",
      "command": "npm test --prefix src/accounting"
    }
  ]
}
